generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String                     @id @default(uuid())
  email                     String?                    @unique
  password                  String
  name                      String
  phone                     String?                    @unique
  farmName                  String
  profilePicture            String?
  refreshToken              String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  otp                       String?
  otpExpiresAt              DateTime?
  fcmToken                  String?
  animals                   Animal[]
  badges                    Badge[]
  communityCommentReactions CommunityCommentReaction[]
  communityComments         CommunityComment[]
  communityPollVotes        CommunityPollVote[]
  communityPostReactions    CommunityPostReaction[]
  communityPosts            CommunityPost[]
  conversations             Conversation[]
  dailyReports              DailyReport[]
  expenses                  Expense[]
  fields                    Field[]
  missions                  Mission[]
  parcels                   Parcel[]
  quizResults               QuizResult[]
  savedArticles             SavedArticle[]
  securityIncidents         SecurityIncident[]
  whitelistStaff            WhitelistStaff[]

  @@map("users")
}

model QuizResult {
  id             String   @id @default(uuid())
  userId         String
  score          Int
  totalQuestions Int
  topic          String
  parcelId       String?
  streak         Int      @default(0)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quiz_results")
}

model Badge {
  id         String   @id @default(uuid())
  userId     String
  name       String
  type       String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("badges")
}

model SavedArticle {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String
  imageUrl    String?
  source      String
  farmerId    String
  createdAt   DateTime @default(now())
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@map("saved_articles")
}

model Field {
  id               String            @id @default(uuid())
  userId           String
  name             String
  cropType         String?
  areaCoordinates  Json
  areaSize         Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  countryCode      String?
  countryId        String?
  fmdFreeZone      Boolean           @default(false)
  regionCode       String?
  regionId         String?
  animals          Animal[]
  country          Country?          @relation(fields: [countryId], references: [id])
  region           FieldRegion?      @relation(fields: [regionId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  missions         Mission[]
  ndviRecords      NDVIRecord[]
  soilMeasurements SoilMeasurement[]

  @@index([userId])
  @@map("fields")
}

model Mission {
  id                String    @id @default(uuid())
  userId            String
  fieldId           String
  title             String
  description       String?
  dueDate           DateTime?
  assignedDate      DateTime  @default(now())
  completedAt       DateTime?
  estimatedDuration Int?
  actualDuration    Int?
  progress          Int       @default(0)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  missionType       String
  status            String    @default("PENDING")
  priority          String    @default("MEDIUM")
  field             Field     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fieldId])
  @@map("missions")
}

model Conversation {
  id        String        @id @default(uuid())
  userId    String
  title     String        @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

model WhitelistStaff {
  id        String   @id @default(uuid())
  name      String
  imagePath String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("whitelist_staff")
}

model SecurityIncident {
  id        String   @id @default(uuid())
  type      String
  imagePath String
  timestamp DateTime @default(now())
  userId    String
  latitude  Float?
  longitude Float?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_incidents")
}

model SoilMeasurement {
  ph                  Float
  soilMoisture        Float    @map("soil_moisture")
  sunlight            Float
  nutrients           Json
  temperature         Float
  latitude            Float
  longitude           Float
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  id                  String   @id @default(uuid())
  fieldId             String?  @map("field_id")
  imagePath           String?  @map("image_path") @db.VarChar
  soilType            String?  @map("soil_type") @db.VarChar
  detectionConfidence Float?   @map("detection_confidence")
  parcelId            String?  @map("parcel_id")
  field               Field?   @relation(fields: [fieldId], references: [id])
  parcel              Parcel?  @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@index([soilType])
  @@index([createdAt])
  @@index([fieldId])
  @@index([latitude, longitude])
  @@index([parcelId])
  @@map("soil_measurements")
}

model Animal {
  id                   String            @id @default(uuid())
  nodeId               String            @unique
  farmerId             String
  name                 String
  animalType           AnimalType
  breed                String?
  sex                  Sex
  tagNumber            String?
  profileImage         String?
  notes                String?
  age                  Int
  ageYears             Int               @default(0)
  isPregnant           Boolean?
  lastInseminationDate DateTime?
  lastBirthDate        DateTime?
  expectedBirthDate    DateTime?
  birthCount           Int               @default(0)
  status               AnimalStatus      @default(active)
  healthStatus         String            @default("OPTIMAL")
  vitalityScore        Int               @default(100)
  bodyTemp             Float?
  activityLevel        String            @default("MODERATE")
  lastVetCheck         DateTime?
  vaccination          Boolean           @default(false)
  healthRiskScore      Float?
  diseaseHistoryCount  Int               @default(0)
  weight               Float?
  milkYield            Float?
  woolYield            Float?
  fatContent           Float?
  protein              Float?
  productionHabit      String?
  feedIntakeRecorded   DateTime?
  dewormingScheduled   DateTime?
  birthHistory         Json?
  dailyMilkAvgL        Decimal?          @db.Decimal(5, 2)
  milkPeakDate         DateTime?
  lactationNumber      Int?
  raceCategory         RaceCategory?
  bestRaceTime         Decimal?          @db.Decimal(8, 3)
  trainingLevel        TrainingLevel?
  woolLastShearDate    DateTime?
  meatGrade            MeatGrade?
  dogRole              DogRole?
  purchasePrice        Decimal?          @db.Decimal(10, 2)
  purchaseDate         DateTime?
  estimatedValue       Decimal?          @db.Decimal(10, 2)
  salePrice            Decimal?          @db.Decimal(10, 2)
  saleDate             DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  fieldId              String
  farmer               User              @relation(fields: [farmerId], references: [id])
  field                Field             @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  expenses             Expense[]
  healthAlerts         HealthAlert[]
  medicalEvents        MedicalEvent[]
  milkProductions      MilkProduction[]
  racePerformances     RacePerformance[]
  sensorReadings       SensorReading[]
  vaccineRecords       VaccineRecord[]
  vaccineSchedules     VaccineSchedule[]
  weightRecords        WeightRecord[]

  @@map("animals")
}

model VaccineRecord {
  id             String           @id @default(uuid())
  animalId       String
  vaccineName    String
  vaccineDate    DateTime
  nextDueDate    DateTime?
  vetName        String?
  lotNumber      String?
  createdAt      DateTime         @default(now())
  scheduleId     String?
  vaccineId      String
  administeredBy String
  administeredAt DateTime
  doseGiven      Float
  doseUnit       String           @default("ml")
  route          VaccineRoute     @default(SUBCUTANEOUS)
  bodyWeight     Float?
  dateEstimated  Boolean          @default(false)
  observations   String?
  animal         Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)
  schedule       VaccineSchedule? @relation(fields: [scheduleId], references: [id])
  vaccine        Vaccine          @relation(fields: [vaccineId], references: [id])

  @@map("vaccine_records")
}

model MedicalEvent {
  id        String           @id @default(uuid())
  animalId  String
  eventDate DateTime
  eventType MedicalEventType
  diagnosis String?
  treatment String?
  vetName   String?
  cost      Decimal?         @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime         @default(now())
  animal    Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("medical_events")
}

model SensorReading {
  id            String   @id @default(uuid())
  animalId      String
  collarId      String?
  timestamp     DateTime
  temperature   Float?
  heartRate     Float?
  accX          Float?
  accY          Float?
  accZ          Float?
  activityScore Float?
  createdAt     DateTime @default(now())
  animal        Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, timestamp])
  @@map("sensor_readings")
}

model HealthAlert {
  id               String     @id @default(uuid())
  animalId         String
  alertTime        DateTime
  alertLevel       AlertLevel
  predictedDisease String?
  confidence       Float?
  anomalyScore     Float?
  vetConfirmed     Boolean?
  notes            String?
  createdAt        DateTime   @default(now())
  animal           Animal     @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("health_alerts")
}

model MilkProduction {
  id        String   @id @default(uuid())
  animalId  String
  date      DateTime
  morningL  Decimal? @db.Decimal(6, 2)
  eveningL  Decimal? @db.Decimal(6, 2)
  totalL    Decimal? @db.Decimal(6, 2)
  notes     String?
  createdAt DateTime @default(now())
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("milk_productions")
}

model RacePerformance {
  id             String   @id @default(uuid())
  animalId       String
  raceDate       DateTime
  raceName       String?
  position       Int?
  timeSeconds    Decimal? @db.Decimal(8, 3)
  distanceM      Int?
  trackCondition String?
  createdAt      DateTime @default(now())
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("race_performances")
}

model WeightRecord {
  id           String   @id @default(uuid())
  animalId     String
  measuredDate DateTime
  weightKg     Decimal  @db.Decimal(7, 2)
  measuredBy   String?
  createdAt    DateTime @default(now())
  animal       Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("weight_records")
}

model Expense {
  id          String   @id @default(uuid())
  animalId    String?
  farmId      String?
  date        DateTime
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  receiptUrl  String?
  createdAt   DateTime @default(now())
  animal      Animal?  @relation(fields: [animalId], references: [id])
  farmer      User?    @relation(fields: [farmId], references: [id])

  @@map("expenses")
}

model Parcel {
  id                    String            @id @default(uuid())
  location              String
  areaSize              Float
  boundariesDescription String
  soilType              String
  soilPh                Float?
  nitrogenLevel         Float?
  phosphorusLevel       Float?
  potassiumLevel        Float?
  waterSource           String
  irrigationMethod      String
  irrigationFrequency   String
  farmerId              String
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  polygon               Json?
  crops                 Crop[]
  fertilizations        Fertilization[]
  harvests              Harvest[]
  farmer                User              @relation(fields: [farmerId], references: [id])
  pests                 PestDisease[]
  soilMeasurements      SoilMeasurement[]

  @@map("parcels")
}

model Crop {
  id                  String   @id @default(uuid())
  cropName            String
  variety             String
  plantingDate        DateTime
  expectedHarvestDate DateTime
  parcelId            String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  parcel              Parcel   @relation(fields: [parcelId], references: [id])

  @@map("crops")
}

model Fertilization {
  id              String   @id @default(uuid())
  fertilizerType  String
  quantityUsed    Float
  applicationDate DateTime
  parcelId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  parcel          Parcel   @relation(fields: [parcelId], references: [id])

  @@map("fertilizations")
}

model PestDisease {
  id            String    @id @default(uuid())
  issueType     String?
  treatmentUsed String?
  treatmentDate DateTime?
  parcelId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  parcel        Parcel    @relation(fields: [parcelId], references: [id])

  @@map("pest_diseases")
}

model Harvest {
  id              String    @id @default(uuid())
  harvestDate     DateTime?
  totalYield      Float?
  yieldPerHectare Float?
  parcelId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  parcel          Parcel    @relation(fields: [parcelId], references: [id])

  @@map("harvests")
}

model CropRequirement {
  id               String @id @default(uuid())
  cropName         String @map("crop_name")
  minPH            Float  @map("min_ph")
  maxPH            Float  @map("max_ph")
  minMoisture      Float  @map("min_moisture")
  maxMoisture      Float  @map("max_moisture")
  nitrogenRequired Float  @map("nitrogen_required")

  @@index([cropName])
  @@map("crop_requirements")
}

model CropRegion {
  id       String @id @default(uuid())
  cropName String @map("crop_name")
  country  String

  @@index([cropName])
  @@index([country])
  @@map("crop_regions")
}

model NDVIRecord {
  id        String   @id @default(uuid())
  fieldId   String
  date      DateTime
  avgNDVI   Float
  gridData  Json
  createdAt DateTime @default(now())
  field     Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId])
  @@map("ndvi_records")
}

model DailyReport {
  id                 String   @id @default(uuid())
  summary            String
  totalIncidents     Int
  criticalAlerts     Int
  peakActivityHour   Int
  averageThreatLevel String
  userId             String
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("daily_reports")
}

model Country {
  id              String                  @id @default(uuid())
  code            String                  @unique
  nameEn          String
  nameFr          String
  nameAr          String?
  vetAuthority    String
  vetAuthorityUrl String?
  oieRegion       OIERegion
  fmdZoneStatus   FMDZoneStatus           @default(ENDEMIC_WITH_VAX)
  timezone        String                  @default("UTC")
  createdAt       DateTime                @default(now())
  regions         FieldRegion[]
  fields          Field[]
  campaigns       VaccineCampaignPeriod[]
  regulations     VaccineRegulation[]

  @@map("countries")
}

model FieldRegion {
  id            String              @id @default(uuid())
  countryId     String
  code          String
  name          String
  fmdZoneStatus FMDZoneStatus
  notes         String?
  country       Country             @relation(fields: [countryId], references: [id])
  fields        Field[]
  regulations   VaccineRegulation[]

  @@unique([countryId, code])
  @@map("field_regions")
}

model Vaccine {
  id                   String              @id @default(uuid())
  code                 String              @unique
  nameFr               String
  nameEn               String
  nameAr               String?
  targetSpecies        Json
  manufacturer         String?
  doseUnit             String              @default("ml")
  defaultIntervalDays  Int                 @default(365)
  isCoreVaccine        Boolean             @default(false)
  intervalDaysOverride Int?
  notes                String?
  createdAt            DateTime            @default(now())
  records              VaccineRecord[]
  regulations          VaccineRegulation[]
  schedules            VaccineSchedule[]

  @@map("vaccines")
}

model VaccineRegulation {
  id                 String           @id @default(uuid())
  countryId          String
  regionId           String?
  vaccineId          String
  species            String
  status             RegulationStatus
  frequency          String?
  intervalDays       Int
  ageMinDays         Int?
  ageMaxDays         Int?
  mandatoryFor       String?
  legalBasis         String?
  isFreeNational     Boolean          @default(false)
  isSubsidized       Boolean          @default(false)
  subsidyAmount      Float?
  seasonalMonthStart Int?
  seasonalMonthEnd   Int?
  notes              String?
  updatedAt          DateTime         @updatedAt
  country            Country          @relation(fields: [countryId], references: [id])
  region             FieldRegion?     @relation(fields: [regionId], references: [id])
  vaccine            Vaccine          @relation(fields: [vaccineId], references: [id])

  @@unique([countryId, regionId, vaccineId, species])
  @@map("vaccine_regulations")
}

model VaccineCampaignPeriod {
  id            String  @id @default(uuid())
  countryId     String
  vaccineCode   String
  species       Json
  startMonth    Int
  endMonth      Int
  isFree        Boolean @default(false)
  isSubsidized  Boolean @default(false)
  subsidyAmount Float?
  notes         String?
  country       Country @relation(fields: [countryId], references: [id])

  @@map("vaccine_campaign_periods")
}

model VaccineSchedule {
  id                 String                   @id @default(uuid())
  animalId           String
  vaccineId          String
  regulationId       String?
  scheduledDate      DateTime
  reminderDaysBefore Int                      @default(3)
  isRecurring        Boolean                  @default(false)
  recurrenceDays     Int?
  isMandatory        Boolean                  @default(false)
  priority           VaccinePriority          @default(MEDIUM)
  status             ScheduleStatus           @default(PENDING)
  notes              String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  notifications      VaccineNotificationLog[]
  records            VaccineRecord[]
  animal             Animal                   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  vaccine            Vaccine                  @relation(fields: [vaccineId], references: [id])

  @@map("vaccine_schedules")
}

model VaccineNotificationLog {
  id         String          @id @default(uuid())
  scheduleId String
  sentAt     DateTime        @default(now())
  type       String
  title      String
  body       String
  success    Boolean         @default(true)
  schedule   VaccineSchedule @relation(fields: [scheduleId], references: [id])

  @@map("vaccine_notification_logs")
}

model CommunityPost {
  id            String                  @id @default(uuid())
  authorId      String
  type          CommunityPostType       @default(STANDARD)
  content       String
  imagePath     String?
  commentsCount Int                     @default(0)
  likesCount    Int                     @default(0)
  dislikesCount Int                     @default(0)
  pollQuestion  String?
  pollEndsAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  comments      CommunityComment[]
  pollOptions   CommunityPollOption[]
  pollVotes     CommunityPollVote[]
  reactions     CommunityPostReaction[]
  author        User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([createdAt])
  @@map("community_posts")
}

model CommunityPostReaction {
  id        String                @id @default(uuid())
  postId    String
  userId    String
  type      CommunityReactionType
  createdAt DateTime              @default(now())
  post      CommunityPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("community_post_reactions")
}

model CommunityComment {
  id              String                     @id @default(uuid())
  postId          String
  authorId        String
  parentCommentId String?
  content         String
  likesCount      Int                        @default(0)
  dislikesCount   Int                        @default(0)
  repliesCount    Int                        @default(0)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  reactions       CommunityCommentReaction[]
  author          User                       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   CommunityComment?          @relation("CommunityCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         CommunityComment[]         @relation("CommunityCommentReplies")
  post            CommunityPost              @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([createdAt])
  @@map("community_comments")
}

model CommunityCommentReaction {
  id        String                @id @default(uuid())
  commentId String
  userId    String
  type      CommunityReactionType
  createdAt DateTime              @default(now())
  comment   CommunityComment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("community_comment_reactions")
}

model CommunityPollOption {
  id         String              @id @default(uuid())
  postId     String
  text       String
  votesCount Int                 @default(0)
  position   Int
  createdAt  DateTime            @default(now())
  post       CommunityPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes      CommunityPollVote[]

  @@unique([postId, position])
  @@index([postId])
  @@map("community_poll_options")
}

model CommunityPollVote {
  id        String              @id @default(uuid())
  postId    String
  optionId  String
  userId    String
  createdAt DateTime            @default(now())
  option    CommunityPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  post      CommunityPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([optionId])
  @@index([userId])
  @@map("community_poll_votes")
}

enum AnimalType {
  horse
  sheep
  cow
  dog
}

enum Sex {
  male
  female
}

enum AnimalStatus {
  sold
  deceased
  active
}

enum RaceCategory {
  sport
  course
  loisir
}

enum TrainingLevel {
  debutant
  confirme
  intermediaire
  elite
  avance
}

enum MeatGrade {
  B
  A
  C
}

enum DogRole {
  berger
  garde
  compagnie
}

enum MedicalEventType {
  disease
  visit
  surgery
  treatment
  other
  checkup
}

enum AlertLevel {
  medium
  low
  critical
  high
}

enum RegulationStatus {
  FORBIDDEN_ZONES
  MANDATORY_ZONES
  VOLUNTARY
  RECOMMENDED
  MANDATORY_CONDITIONAL
  FORBIDDEN
  UNDER_ERADICATION
  NOT_APPLICABLE
  MANDATORY
}

enum FMDZoneStatus {
  FREE_WITHOUT_VAX
  SURVEILLANCE
  ENDEMIC_WITH_VAX
  FREE_WITH_VAX
}

enum ScheduleStatus {
  DONE
  NOTIFIED
  OVERDUE
  CANCELLED
  PENDING
}

enum VaccineRoute {
  INTRANASAL
  INTRAMUSCULAR
  SUBCUTANEOUS
  ORAL
}

enum VaccinePriority {
  HIGH
  LOW
  MEDIUM
}

enum OIERegion {
  EUROPE_EAST
  MIDDLE_EAST
  AMERICAS_SOUTH
  ASIA_PACIFIC
  AMERICAS_CENTRAL
  EUROPE_WEST
  AFRICA_SUB_SAHARAN
  AMERICAS_NORTH
  AFRICA_NORTH
}

enum CommunityPostType {
  VOTE
  STANDARD
}

