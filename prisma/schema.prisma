generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  email             String?            @unique
  password          String
  name              String
  phone             String?            @unique
  farmName          String
  profilePicture    String?
  refreshToken      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  otp               String?
  otpExpiresAt      DateTime?
  fcmToken          String?
  animals           Animal[]
  conversations     Conversation[]
  expenses          Expense[]
  fields            Field[]
  missions          Mission[]
  parcels           Parcel[]
  savedArticles     SavedArticle[]
  securityIncidents SecurityIncident[]
  whitelistStaff    WhitelistStaff[]
  quizResults       QuizResult[]
  badges            Badge[]

  @@map("users")
}

model QuizResult {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score           Int
  totalQuestions  Int
  topic           String
  parcelId        String?
  streak          Int      @default(0)
  createdAt       DateTime @default(now())

  @@map("quiz_results")
  @@index([userId])
}

model Badge {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String
  unlockedAt  DateTime @default(now())

  @@map("badges")
  @@unique([userId, type])
}


model SavedArticle {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String
  imageUrl    String?
  source      String
  farmerId    String
  createdAt   DateTime @default(now())
  farmer      User     @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@map("saved_articles")
}

model Field {
  id              String    @id @default(uuid())
  userId          String
  name            String
  cropType        String?
  areaCoordinates Json
  areaSize        Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  countryCode     String?
  countryId       String?
  fmdFreeZone     Boolean   @default(false)
  regionCode      String?
  regionId        String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  missions        Mission[]

  @@index([userId])
  @@map("fields")
}

model Mission {
  id                String    @id @default(uuid())
  userId            String
  fieldId           String
  title             String
  description       String?
  dueDate           DateTime?
  assignedDate      DateTime  @default(now())
  completedAt       DateTime?
  estimatedDuration Int?
  actualDuration    Int?
  progress          Int       @default(0)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  missionType       String
  status            String    @default("PENDING")
  priority          String    @default("MEDIUM")
  field             Field     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fieldId])
  @@map("missions")
}

model Conversation {
  id        String        @id @default(uuid())
  userId    String
  title     String        @default("New Conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

model WhitelistStaff {
  id        String   @id @default(uuid())
  name      String
  imagePath String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("whitelist_staff")
}

model SecurityIncident {
  id        String   @id @default(uuid())
  type      String
  imagePath String
  timestamp DateTime @default(now())
  userId    String
  latitude  Float?
  longitude Float?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_incidents")
}

model SoilMeasurement {
  ph                  Float
  soilMoisture        Float    @map("soil_moisture")
  sunlight            Float
  nutrients           Json
  temperature         Float
  latitude            Float
  longitude           Float
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  id                  String   @id(map: "PK_26b4f52c4005e567602987343a6") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fieldId             String?  @map("field_id") @db.Uuid
  imagePath           String?  @map("image_path") @db.VarChar
  soilType            String?  @map("soil_type") @db.VarChar
  detectionConfidence Float?   @map("detection_confidence")

  @@index([soilType], map: "IDX_0a742379a0b58d214968308ae8")
  @@index([createdAt], map: "IDX_1b5048dedf4b0c67b0e3d69028")
  @@index([fieldId], map: "IDX_b1d30f7933303444ba94550db7")
  @@index([latitude, longitude], map: "IDX_db34dddb4edfd4e726c70f52b0")
  @@map("soil_measurements")
}

model Animal {
  id                   String            @id @default(uuid())
  nodeId               String            @unique
  farmerId             String
  name                 String
  animalType           AnimalType
  breed                String?
  sex                  Sex
  tagNumber            String?
  profileImage         String?
  notes                String?
  age                  Int
  ageYears             Int               @default(0)
  isPregnant           Boolean?
  lastInseminationDate DateTime?
  lastBirthDate        DateTime?
  expectedBirthDate    DateTime?
  birthCount           Int               @default(0)
  status               AnimalStatus      @default(active)
  healthStatus         String            @default("OPTIMAL")
  vitalityScore        Int               @default(100)
  bodyTemp             Float?
  activityLevel        String            @default("MODERATE")
  lastVetCheck         DateTime?
  vaccination          Boolean           @default(false)
  healthRiskScore      Float?
  diseaseHistoryCount  Int               @default(0)
  weight               Float?
  milkYield            Float?
  woolYield            Float?
  fatContent           Float?
  protein              Float?
  productionHabit      String?
  feedIntakeRecorded   DateTime?
  dewormingScheduled   DateTime?
  birthHistory         Json?
  dailyMilkAvgL        Decimal?          @db.Decimal(5, 2)
  milkPeakDate         DateTime?
  lactationNumber      Int?
  raceCategory         RaceCategory?
  bestRaceTime         Decimal?          @db.Decimal(8, 3)
  trainingLevel        TrainingLevel?
  woolLastShearDate    DateTime?
  meatGrade            MeatGrade?
  dogRole              DogRole?
  purchasePrice        Decimal?          @db.Decimal(10, 2)
  purchaseDate         DateTime?
  estimatedValue       Decimal?          @db.Decimal(10, 2)
  salePrice            Decimal?          @db.Decimal(10, 2)
  saleDate             DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  fieldId              String
  farmer               User              @relation(fields: [farmerId], references: [id])
  expenses             Expense[]
  healthAlerts         HealthAlert[]
  medicalEvents        MedicalEvent[]
  milkProductions      MilkProduction[]
  racePerformances     RacePerformance[]
  sensorReadings       SensorReading[]
  vaccineRecords       VaccineRecord[]
  weightRecords        WeightRecord[]

  @@map("animals")
}

model VaccineRecord {
  id          String    @id @default(uuid())
  animalId    String
  vaccineName String
  vaccineDate DateTime
  nextDueDate DateTime?
  vetName     String?
  lotNumber   String?
  createdAt   DateTime  @default(now())
  animal      Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("vaccine_records")
}

model MedicalEvent {
  id        String           @id @default(uuid())
  animalId  String
  eventDate DateTime
  eventType MedicalEventType
  diagnosis String?
  treatment String?
  vetName   String?
  cost      Decimal?         @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime         @default(now())
  animal    Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("medical_events")
}

model SensorReading {
  id            String   @id @default(uuid())
  animalId      String
  collarId      String?
  timestamp     DateTime
  temperature   Float?
  heartRate     Float?
  accX          Float?
  accY          Float?
  accZ          Float?
  activityScore Float?
  createdAt     DateTime @default(now())
  animal        Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, timestamp])
  @@map("sensor_readings")
}

model HealthAlert {
  id               String     @id @default(uuid())
  animalId         String
  alertTime        DateTime
  alertLevel       AlertLevel
  predictedDisease String?
  confidence       Float?
  anomalyScore     Float?
  vetConfirmed     Boolean?
  notes            String?
  createdAt        DateTime   @default(now())
  animal           Animal     @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("health_alerts")
}

model MilkProduction {
  id        String   @id @default(uuid())
  animalId  String
  date      DateTime
  morningL  Decimal? @db.Decimal(6, 2)
  eveningL  Decimal? @db.Decimal(6, 2)
  totalL    Decimal? @db.Decimal(6, 2)
  notes     String?
  createdAt DateTime @default(now())
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("milk_productions")
}

model RacePerformance {
  id             String   @id @default(uuid())
  animalId       String
  raceDate       DateTime
  raceName       String?
  position       Int?
  timeSeconds    Decimal? @db.Decimal(8, 3)
  distanceM      Int?
  trackCondition String?
  createdAt      DateTime @default(now())
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("race_performances")
}

model WeightRecord {
  id           String   @id @default(uuid())
  animalId     String
  measuredDate DateTime
  weightKg     Decimal  @db.Decimal(7, 2)
  measuredBy   String?
  createdAt    DateTime @default(now())
  animal       Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("weight_records")
}

model Expense {
  id          String   @id @default(uuid())
  animalId    String?
  farmId      String?
  date        DateTime
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  receiptUrl  String?
  createdAt   DateTime @default(now())
  animal      Animal?  @relation(fields: [animalId], references: [id])
  farmer      User?    @relation(fields: [farmId], references: [id])

  @@map("expenses")
}

model Parcel {
  id                    String          @id @default(uuid())
  location              String
  areaSize              Float
  boundariesDescription String
  soilType              String
  soilPh                Float?
  nitrogenLevel         Float?
  phosphorusLevel       Float?
  potassiumLevel        Float?
  waterSource           String
  irrigationMethod      String
  irrigationFrequency   String
  farmerId              String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  crops                 Crop[]
  fertilizations        Fertilization[]
  harvests              Harvest[]
  farmer                User            @relation(fields: [farmerId], references: [id])
  pests                 PestDisease[]

  @@map("parcels")
}

model Crop {
  id                  String   @id @default(uuid())
  cropName            String
  variety             String
  plantingDate        DateTime
  expectedHarvestDate DateTime
  parcelId            String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  parcel              Parcel   @relation(fields: [parcelId], references: [id])

  @@map("crops")
}

model Fertilization {
  id              String   @id @default(uuid())
  fertilizerType  String
  quantityUsed    Float
  applicationDate DateTime
  parcelId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  parcel          Parcel   @relation(fields: [parcelId], references: [id])

  @@map("fertilizations")
}

model PestDisease {
  id            String    @id @default(uuid())
  issueType     String?
  treatmentUsed String?
  treatmentDate DateTime?
  parcelId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  parcel        Parcel    @relation(fields: [parcelId], references: [id])

  @@map("pest_diseases")
}

model Harvest {
  id              String    @id @default(uuid())
  harvestDate     DateTime?
  totalYield      Float?
  yieldPerHectare Float?
  parcelId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  parcel          Parcel    @relation(fields: [parcelId], references: [id])

  @@map("harvests")
}

model CropRequirement {
  id               String @id @default(uuid())
  cropName         String @map("crop_name")
  minPH            Float  @map("min_ph")
  maxPH            Float  @map("max_ph")
  minMoisture      Float  @map("min_moisture")
  maxMoisture      Float  @map("max_moisture")
  nitrogenRequired Float  @map("nitrogen_required")

  @@index([cropName])
  @@map("crop_requirements")
}

model CropRegion {
  id       String @id @default(uuid())
  cropName String @map("crop_name")
  country  String

  @@index([cropName])
  @@index([country])
  @@map("crop_regions")
}

enum AnimalType {
  cow
  horse
  sheep
  dog
}

enum Sex {
  male
  female
}

enum AnimalStatus {
  active
  sold
  deceased
}

enum RaceCategory {
  course
  loisir
  sport
}

enum TrainingLevel {
  debutant
  intermediaire
  avance
  confirme
  elite
}

enum MeatGrade {
  A
  B
  C
}

enum DogRole {
  garde
  berger
  compagnie
}

enum MedicalEventType {
  visit
  disease
  surgery
  treatment
  checkup
  other
}

enum AlertLevel {
  low
  medium
  high
  critical
}

enum RegulationStatus {
  MANDATORY
  MANDATORY_ZONES
  MANDATORY_CONDITIONAL
  RECOMMENDED
  VOLUNTARY
  FORBIDDEN
  FORBIDDEN_ZONES
  NOT_APPLICABLE
  UNDER_ERADICATION
}

enum FMDZoneStatus {
  ENDEMIC_WITH_VAX
  FREE_WITH_VAX
  FREE_WITHOUT_VAX
  SURVEILLANCE
}

enum ScheduleStatus {
  PENDING
  NOTIFIED
  DONE
  OVERDUE
  CANCELLED
}

enum VaccineRoute {
  SUBCUTANEOUS
  INTRAMUSCULAR
  INTRANASAL
  ORAL
}

enum VaccinePriority {
  HIGH
  MEDIUM
  LOW
}

enum OIERegion {
  AFRICA_NORTH
  AFRICA_SUB_SAHARAN
  EUROPE_WEST
  EUROPE_EAST
  AMERICAS_NORTH
  AMERICAS_SOUTH
  AMERICAS_CENTRAL
  ASIA_PACIFIC
  MIDDLE_EAST
}

enum CommunityPostType {
  STANDARD
  VOTE
}

enum CommunityReactionType {
  LIKE
  DISLIKE
}
